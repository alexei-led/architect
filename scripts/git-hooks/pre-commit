#!/usr/bin/env bash
set -euo pipefail

echo "=== pre-commit ==="

command -v git >/dev/null 2>&1 || { echo "git not installed" >&2; exit 1; }
command -v gitleaks >/dev/null 2>&1 || { echo "gitleaks not installed" >&2; exit 1; }
command -v uv >/dev/null 2>&1 || { echo "uv not installed" >&2; exit 1; }

gitleaks git --staged --redact --no-banner

mapfile -d '' staged_python_files < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.py')

if ((${#staged_python_files[@]} == 0)); then
	echo "pre-commit: no staged Python files"
	exit 0
fi

uv run ruff check -- "${staged_python_files[@]}"
uv run ruff format --check -- "${staged_python_files[@]}"
