#!/usr/bin/env bash
set -euo pipefail

command -v make >/dev/null 2>&1 || { echo "make not installed" >&2; exit 1; }
command -v gitleaks >/dev/null 2>&1 || { echo "gitleaks not installed" >&2; exit 1; }

all_deletes=1
have_input=0
while read -r local_ref local_sha remote_ref remote_sha; do
	have_input=1
	if [[ "$local_sha" != "0000000000000000000000000000000000000000" ]]; then
		all_deletes=0
	fi
	: "$local_ref" "$remote_ref" "$remote_sha"
done

if [[ $have_input -eq 1 && $all_deletes -eq 1 ]]; then
	echo "pre-push: deletion-only push, skipping"
	exit 0
fi

echo "=== pre-push ==="
make check
gitleaks git --redact --no-banner
