#!/usr/bin/env bash
set -euo pipefail

all_deletes=1
have_input=0
while read -r local_ref _ _ _; do
	have_input=1
	[[ "$local_ref" == "(delete)" ]] || all_deletes=0
done

if [[ $have_input -eq 1 && $all_deletes -eq 1 ]]; then
	echo "pre-push: deletion-only push, skipping"
	exit 0
fi

echo "=== pre-push ==="
make check

command -v gitleaks >/dev/null 2>&1 || { echo "gitleaks not installed"; exit 1; }
gitleaks git --redact --no-banner
